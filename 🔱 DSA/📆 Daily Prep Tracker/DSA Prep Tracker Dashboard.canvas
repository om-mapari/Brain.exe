	"nodes":[
		{
			"id":"node1",
			"type":"text",
			"text":"```dataviewjs\n// Configuration\nconst habitProperty = \"dsa_completed\"; // The property to track\nconst habitTitle = \"🔱 DSA Completed\";\nconst countLabel = \"Total DSA Problems Solved\"; // Custom label for total count\n\n// Create a unique ID for this calendar instance\nconst containerId = `habit-calendar-${habitProperty}`;\n\n// Function to calculate streak statistics\nfunction calculateStreaks(habitData, year, month) {\n    const allDates = Array.from(habitData.entries())\n        .filter(([date, completed]) => completed === true)\n        .map(([date]) => date)\n        .sort();\n    \n    const totalDays = habitData.size;\n    const completedDays = allDates.length;\n    const completionPercentage = totalDays > 0 ? Math.round((completedDays / totalDays) * 100) : 0;\n    \n    if (allDates.length === 0) {\n        return { currentStreak: 0, longestStreak: 0, longestBreak: 0, totalCompleted: 0, completionPercentage: completionPercentage };\n    }\n    \n    let currentStreak = 0;\n    let longestStreak = 0;\n    let longestBreak = 0;\n    let tempStreak = 1;\n    let tempBreak = 0;\n    \n    const today = dv.date(\"today\").toFormat('yyyy-MM-dd');\n    const yesterday = dv.date(\"today\").minus({days: 1}).toFormat('yyyy-MM-dd');\n    \n    if (allDates.includes(today) || allDates.includes(yesterday)) {\n        let checkDate = allDates.includes(today) ? dv.date(\"today\") : dv.date(\"today\").minus({days: 1});\n        currentStreak = 0;\n        while (true) {\n            const dateKey = checkDate.toFormat('yyyy-MM-dd');\n            if (habitData.get(dateKey) === true) {\n                currentStreak++;\n                checkDate = checkDate.minus({days: 1});\n            } else {\n                break;\n            }\n        }\n    }\n    \n    for (let i = 1; i < allDates.length; i++) {\n        const prevDate = dv.date(allDates[i - 1]);\n        const currDate = dv.date(allDates[i]);\n        const daysDiff = currDate.diff(prevDate, 'days').days;\n        \n        if (daysDiff === 1) {\n            tempStreak++;\n            if (tempBreak > 0) {\n                longestBreak = Math.max(longestBreak, tempBreak);\n                tempBreak = 0;\n            }\n        } else {\n            longestStreak = Math.max(longestStreak, tempStreak);\n            tempStreak = 1;\n            tempBreak = daysDiff - 1;\n            longestBreak = Math.max(longestBreak, tempBreak);\n        }\n    }\n    longestStreak = Math.max(longestStreak, tempStreak);\n    \n    return { currentStreak, longestStreak, longestBreak, totalCompleted: completedDays, completionPercentage };\n}\n\n// Function to render the calendar\nfunction renderCalendar(monthOffset) {\n    const currentDate = dv.date(\"today\").plus({months: monthOffset});\n    const year = currentDate.year;\n    const month = currentDate.month;\n\n    const pages = dv.pages('\"🔱 DSA/📆 Daily Prep Tracker\"')\n        .where(p => p.file.day && p[habitProperty] !== undefined)\n        .sort(p => p.file.day, 'asc');\n\n    const habitData = new Map();\n    let totalCount = 0;\n    \n    pages.forEach(p => {\n        const dateKey = p.file.day.toFormat('yyyy-MM-dd');\n        let isDone = false;\n        if (typeof p[habitProperty] === 'number') {\n            isDone = p[habitProperty] > 0;\n            totalCount += p[habitProperty];\n        } else {\n            isDone = p[habitProperty] === true;\n        }\n        habitData.set(dateKey, isDone);\n    });\n\n    const stats = calculateStreaks(habitData, year, month);\n    const firstDay = dv.date(`${year}-${String(month).padStart(2, '0')}-01`);\n    const lastDay = firstDay.plus({months: 1}).minus({days: 1});\n    const daysInMonth = lastDay.day;\n    const luxonWeekday = firstDay.weekday;\n    const startDayOfWeek = luxonWeekday === 7 ? 6 : luxonWeekday - 1;\n    const monthName = firstDay.toFormat('MMMM yyyy');\n    const todayKey = dv.date(\"today\").toFormat('yyyy-MM-dd');\n\n    const cells = [];\n    if (startDayOfWeek > 0) {\n        const prevMonthLastDay = firstDay.minus({days: 1});\n        const prevMonthDaysInMonth = prevMonthLastDay.day;\n        for (let i = startDayOfWeek - 1; i >= 0; i--) {\n            const day = prevMonthDaysInMonth - i;\n            const prevMonthDate = firstDay.minus({days: i + 1});\n            const dateKey = prevMonthDate.toFormat('yyyy-MM-dd');\n            cells.push({\n                isEmpty: false, isPrevMonth: true, day: day, dateKey: dateKey,\n                isCompleted: habitData.get(dateKey) === true, hasData: habitData.has(dateKey), isToday: dateKey === todayKey\n            });\n        }\n    }\n    for (let day = 1; day <= daysInMonth; day++) {\n        const dateKey = `${year}-${String(month).padStart(2, '0')}-${String(day).padStart(2, '0')}`;\n        cells.push({\n            isEmpty: false, isPrevMonth: false, day: day, dateKey: dateKey,\n            isCompleted: habitData.get(dateKey) === true, hasData: habitData.has(dateKey), isToday: dateKey === todayKey\n        });\n    }\n\n    let html = `\n    <h1 style=\"margin: 10px 0 20px 0; text-align: center;\">${habitTitle}</h1>\n    <div style=\"display: flex; align-items: center; justify-content: space-between; margin-bottom: 15px;\">\n        <button class=\"prev-month\" style=\"padding: 6px 12px; cursor: pointer; background: var(--interactive-normal); border: 1px solid var(--background-modifier-border); border-radius: 4px; color: var(--text-normal);\">← Prev</button>\n        <h3 style=\"margin: 0;\">${monthName}</h3>\n        <button class=\"next-month\" style=\"padding: 6px 12px; cursor: pointer; background: var(--interactive-normal); border: 1px solid var(--background-modifier-border); border-radius: 4px; color: var(--text-normal);\">Next →</button>\n    </div>\n    <div style=\"display: grid; grid-template-columns: repeat(7, 1fr); gap: 12px; margin-bottom: 15px;\">\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Mon</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Tue</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Wed</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Thu</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Fri</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Sat</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Sun</div>\n    `;\n\n    cells.forEach((cell, index) => {\n        if (cell.isEmpty) { html += '<div style=\"height: 50px;\"></div>'; return; }\n        const posInRow = index % 7;\n        const isLastInRow = posInRow === 6;\n        const isFirstInRow = posInRow === 0;\n        const prevCell = index > 0 ? cells[index - 1] : null;\n        const nextCell = index < cells.length - 1 ? cells[index + 1] : null;\n        \n        const hasLineFromPrev = prevCell && !prevCell.isEmpty && prevCell.isCompleted && cell.isCompleted && !isFirstInRow;\n        const hasLineToNext = nextCell && !nextCell.isEmpty && nextCell.isCompleted && cell.isCompleted && !isLastInRow;\n        const hasWrapLineFromPrev = prevCell && !prevCell.isEmpty && prevCell.isCompleted && cell.isCompleted && isFirstInRow;\n        const hasWrapLineToNext = nextCell && !nextCell.isEmpty && nextCell.isCompleted && cell.isCompleted && isLastInRow;\n        \n        const dotColor = cell.isPrevMonth ? '#1a5c28' : '#2CC742';\n        const lineColor = cell.isPrevMonth ? '#1a5c28' : '#2CC742';\n        const completedTextColor = cell.isPrevMonth ? '#888' : 'white';\n        const missedTextColor = cell.isPrevMonth ? '#888' : 'var(--text-normal)';\n        \n        let dotStyle = `width: 50px; height: 50px; border-radius: 50%; margin: 0 auto; position: relative; z-index: 2; display: flex; align-items: center; justify-content: center; font-weight: 500; font-size: 1em; cursor: pointer;`;\n        \n        if (cell.hasData) {\n            if (cell.isCompleted) {\n                dotStyle += `background-color: ${dotColor}; color: ${completedTextColor};`;\n            } else {\n                dotStyle += `background-color: transparent; border: 3px solid ${cell.isPrevMonth ? '#7d3a37' : '#FE5F58'}; color: ${missedTextColor};`;\n            }\n        } else {\n            dotStyle += `background-color: transparent; color: ${cell.isPrevMonth ? '#666' : 'var(--text-muted)'};`;\n        }\n        if (cell.isToday && cell.hasData) dotStyle += 'box-shadow: 0 0 0 3px var(--interactive-accent);';\n        \n        let lineHTML = '';\n        const leftLineColor = (hasLineFromPrev && prevCell.isPrevMonth && cell.isPrevMonth) ? '#1a5c28' : lineColor;\n        const rightLineColor = (hasLineToNext && cell.isPrevMonth && nextCell.isPrevMonth) ? '#1a5c28' : lineColor;\n        \n        if (hasLineFromPrev) lineHTML += `<div style=\"position: absolute; width: calc(50% + 12px); height: 3px; background-color: ${leftLineColor}; top: 50%; left: -12px; transform: translateY(-50%); z-index: 1;\"></div>`;\n        if (hasLineToNext) lineHTML += `<div style=\"position: absolute; width: calc(50% + 12px); height: 3px; background-color: ${rightLineColor}; top: 50%; right: -12px; transform: translateY(-50%); z-index: 1;\"></div>`;\n        if (hasWrapLineFromPrev) lineHTML += `<div style=\"position: absolute; width: calc(50% + 12px); height: 3px; background-color: ${leftLineColor}; top: 50%; left: -12px; transform: translateY(-50%); z-index: 1;\"></div>`;\n        if (hasWrapLineToNext) lineHTML += `<div style=\"position: absolute; width: calc(50% + 12px); height: 3px; background-color: ${rightLineColor}; top: 50%; right: -12px; transform: translateY(-50%); z-index: 1;\"></div>`;\n        \n        html += `<div style=\"text-align: center; position: relative; height: 50px;\">${lineHTML}<div class=\"date-link\" data-date=\"${cell.dateKey}\" style=\"${dotStyle}\">${cell.day}</div></div>`;\n    });\n\n    let extraStatHtml = '';\n    if (countLabel !== 'none') {\n        extraStatHtml = `\n        <div style=\"margin-top: 15px; padding: 15px; background: var(--background-secondary); border-radius: 8px; text-align: center;\">\n            <div style=\"font-size: 2em; font-weight: 700; color: #2CC742;\">${totalCount}</div>\n            <div style=\"font-size: 0.9em; color: var(--text-muted); margin-top: 4px;\">$Total DSA Problems Solved</div>\n        </div>\n        `;\n    }\n\n    html += `\n    </div>\n    <div style=\"margin-top: 20px; display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; padding: 15px; background: var(--background-secondary); border-radius: 8px;\">\n        <div style=\"text-align: center;\"><div style=\"font-size: 1.5em; font-weight: 700; color: #2CC742;\">${stats.currentStreak}</div><div style=\"font-size: 0.85em; color: var(--text-muted); margin-top: 4px;\">Current Streak</div></div>\n        <div style=\"text-align: center;\"><div style=\"font-size: 1.5em; font-weight: 700; color: #DAA520;\">${stats.longestStreak}</div><div style=\"font-size: 0.85em; color: var(--text-muted); margin-top: 4px;\">Longest Streak</div></div>\n        <div style=\"text-align: center;\"><div style=\"font-size: 1.5em; font-weight: 700; color: #FE5F58;\">${stats.longestBreak}</div><div style=\"font-size: 0.85em; color: var(--text-muted); margin-top: 4px;\">Longest Break</div></div>\n        <div style=\"text-align: center;\"><div style=\"font-size: 1.5em; font-weight: 700; color: var(--text-normal);\">${stats.completionPercentage}%</div><div style=\"font-size: 0.85em; color: var(--text-muted); margin-top: 4px;\">Completion %</div></div>\n        <div style=\"text-align: center;\"><div style=\"font-size: 1.5em; font-weight: 700; color: var(--text-normal);\">${stats.totalCompleted}</div><div style=\"font-size: 0.85em; color: var(--text-muted); margin-top: 4px;\">Total Days</div></div>\n    </div>\n    ${extraStatHtml}\n    `;\n    return html;\n}\n\nlet currentOffset = 0;\nconst container = dv.container;\ncontainer.innerHTML = `<div id=\"${containerId}\" style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\">${renderCalendar(currentOffset)}</div>`;\n\nfunction setupListeners() {\n    const calendarDiv = container.querySelector(`#${containerId}`);\n    calendarDiv.querySelector('.prev-month').addEventListener('click', () => { currentOffset--; calendarDiv.innerHTML = renderCalendar(currentOffset); setupListeners(); });\n    calendarDiv.querySelector('.next-month').addEventListener('click', () => { currentOffset++; calendarDiv.innerHTML = renderCalendar(currentOffset); setupListeners(); });\n    calendarDiv.querySelectorAll('.date-link').forEach(link => {\n        link.addEventListener('click', (e) => {\n            const dateKey = e.target.getAttribute('data-date');\n            app.workspace.openLinkText(`🔱 DSA/📆 Daily Prep Tracker/${dateKey}.md`, '', false);\n        });\n    });\n}\nsetupListeners();\n```",
			"styleAttributes":{},
			"x":-620,
			"y":-1080,
			"width":480,
			"height":760
		},
		{
			"id":"node2",
			"type":"text",
			"text":"```dataviewjs\n// Configuration\nconst habitProperty = \"sd_completed\"; // The property to track\nconst habitTitle = \"🚀 System Design\";\nconst countLabel = \"Total System Design Topics\"; // Custom label for total count\n\n// Create a unique ID for this calendar instance\nconst containerId = `habit-calendar-${habitProperty}`;\n\n// Function to calculate streak statistics\nfunction calculateStreaks(habitData, year, month) {\n    const allDates = Array.from(habitData.entries())\n        .filter(([date, completed]) => completed === true)\n        .map(([date]) => date)\n        .sort();\n    \n    const totalDays = habitData.size;\n    const completedDays = allDates.length;\n    const completionPercentage = totalDays > 0 ? Math.round((completedDays / totalDays) * 100) : 0;\n    \n    if (allDates.length === 0) {\n        return { currentStreak: 0, longestStreak: 0, longestBreak: 0, totalCompleted: 0, completionPercentage: completionPercentage };\n    }\n    \n    let currentStreak = 0;\n    let longestStreak = 0;\n    let longestBreak = 0;\n    let tempStreak = 1;\n    let tempBreak = 0;\n    \n    const today = dv.date(\"today\").toFormat('yyyy-MM-dd');\n    const yesterday = dv.date(\"today\").minus({days: 1}).toFormat('yyyy-MM-dd');\n    \n    if (allDates.includes(today) || allDates.includes(yesterday)) {\n        let checkDate = allDates.includes(today) ? dv.date(\"today\") : dv.date(\"today\").minus({days: 1});\n        currentStreak = 0;\n        while (true) {\n            const dateKey = checkDate.toFormat('yyyy-MM-dd');\n            if (habitData.get(dateKey) === true) {\n                currentStreak++;\n                checkDate = checkDate.minus({days: 1});\n            } else {\n                break;\n            }\n        }\n    }\n    \n    for (let i = 1; i < allDates.length; i++) {\n        const prevDate = dv.date(allDates[i - 1]);\n        const currDate = dv.date(allDates[i]);\n        const daysDiff = currDate.diff(prevDate, 'days').days;\n        \n        if (daysDiff === 1) {\n            tempStreak++;\n            if (tempBreak > 0) {\n                longestBreak = Math.max(longestBreak, tempBreak);\n                tempBreak = 0;\n            }\n        } else {\n            longestStreak = Math.max(longestStreak, tempStreak);\n            tempStreak = 1;\n            tempBreak = daysDiff - 1;\n            longestBreak = Math.max(longestBreak, tempBreak);\n        }\n    }\n    longestStreak = Math.max(longestStreak, tempStreak);\n    \n    return { currentStreak, longestStreak, longestBreak, totalCompleted: completedDays, completionPercentage };\n}\n\n// Function to render the calendar\nfunction renderCalendar(monthOffset) {\n    const currentDate = dv.date(\"today\").plus({months: monthOffset});\n    const year = currentDate.year;\n    const month = currentDate.month;\n\n    const pages = dv.pages('\"🔱 DSA/📆 Daily Prep Tracker\"')\n        .where(p => p.file.day && p[habitProperty] !== undefined)\n        .sort(p => p.file.day, 'asc');\n\n    const habitData = new Map();\n    let totalCount = 0;\n    \n    pages.forEach(p => {\n        const dateKey = p.file.day.toFormat('yyyy-MM-dd');\n        let isDone = false;\n        if (typeof p[habitProperty] === 'number') {\n            isDone = p[habitProperty] > 0;\n            totalCount += p[habitProperty];\n        } else {\n            isDone = p[habitProperty] === true;\n        }\n        habitData.set(dateKey, isDone);\n    });\n\n    const stats = calculateStreaks(habitData, year, month);\n    const firstDay = dv.date(`${year}-${String(month).padStart(2, '0')}-01`);\n    const lastDay = firstDay.plus({months: 1}).minus({days: 1});\n    const daysInMonth = lastDay.day;\n    const luxonWeekday = firstDay.weekday;\n    const startDayOfWeek = luxonWeekday === 7 ? 6 : luxonWeekday - 1;\n    const monthName = firstDay.toFormat('MMMM yyyy');\n    const todayKey = dv.date(\"today\").toFormat('yyyy-MM-dd');\n\n    const cells = [];\n    if (startDayOfWeek > 0) {\n        const prevMonthLastDay = firstDay.minus({days: 1});\n        const prevMonthDaysInMonth = prevMonthLastDay.day;\n        for (let i = startDayOfWeek - 1; i >= 0; i--) {\n            const day = prevMonthDaysInMonth - i;\n            const prevMonthDate = firstDay.minus({days: i + 1});\n            const dateKey = prevMonthDate.toFormat('yyyy-MM-dd');\n            cells.push({\n                isEmpty: false, isPrevMonth: true, day: day, dateKey: dateKey,\n                isCompleted: habitData.get(dateKey) === true, hasData: habitData.has(dateKey), isToday: dateKey === todayKey\n            });\n        }\n    }\n    for (let day = 1; day <= daysInMonth; day++) {\n        const dateKey = `${year}-${String(month).padStart(2, '0')}-${String(day).padStart(2, '0')}`;\n        cells.push({\n            isEmpty: false, isPrevMonth: false, day: day, dateKey: dateKey,\n            isCompleted: habitData.get(dateKey) === true, hasData: habitData.has(dateKey), isToday: dateKey === todayKey\n        });\n    }\n\n    let html = `\n    <h1 style=\"margin: 10px 0 20px 0; text-align: center;\">${habitTitle}</h1>\n    <div style=\"display: flex; align-items: center; justify-content: space-between; margin-bottom: 15px;\">\n        <button class=\"prev-month\" style=\"padding: 6px 12px; cursor: pointer; background: var(--interactive-normal); border: 1px solid var(--background-modifier-border); border-radius: 4px; color: var(--text-normal);\">← Prev</button>\n        <h3 style=\"margin: 0;\">${monthName}</h3>\n        <button class=\"next-month\" style=\"padding: 6px 12px; cursor: pointer; background: var(--interactive-normal); border: 1px solid var(--background-modifier-border); border-radius: 4px; color: var(--text-normal);\">Next →</button>\n    </div>\n    <div style=\"display: grid; grid-template-columns: repeat(7, 1fr); gap: 12px; margin-bottom: 15px;\">\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Mon</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Tue</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Wed</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Thu</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Fri</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Sat</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Sun</div>\n    `;\n\n    cells.forEach((cell, index) => {\n        if (cell.isEmpty) { html += '<div style=\"height: 50px;\"></div>'; return; }\n        const posInRow = index % 7;\n        const isLastInRow = posInRow === 6;\n        const isFirstInRow = posInRow === 0;\n        const prevCell = index > 0 ? cells[index - 1] : null;\n        const nextCell = index < cells.length - 1 ? cells[index + 1] : null;\n        \n        const hasLineFromPrev = prevCell && !prevCell.isEmpty && prevCell.isCompleted && cell.isCompleted && !isFirstInRow;\n        const hasLineToNext = nextCell && !nextCell.isEmpty && nextCell.isCompleted && cell.isCompleted && !isLastInRow;\n        const hasWrapLineFromPrev = prevCell && !prevCell.isEmpty && prevCell.isCompleted && cell.isCompleted && isFirstInRow;\n        const hasWrapLineToNext = nextCell && !nextCell.isEmpty && nextCell.isCompleted && cell.isCompleted && isLastInRow;\n        \n        const dotColor = cell.isPrevMonth ? '#1a5c28' : '#3b82f6';\n        const lineColor = cell.isPrevMonth ? '#1a5c28' : '#3b82f6';\n        const completedTextColor = cell.isPrevMonth ? '#888' : 'white';\n        const missedTextColor = cell.isPrevMonth ? '#888' : 'var(--text-normal)';\n        \n        let dotStyle = `width: 50px; height: 50px; border-radius: 50%; margin: 0 auto; position: relative; z-index: 2; display: flex; align-items: center; justify-content: center; font-weight: 500; font-size: 1em; cursor: pointer;`;\n        \n        if (cell.hasData) {\n            if (cell.isCompleted) {\n                dotStyle += `background-color: ${dotColor}; color: ${completedTextColor};`;\n            } else {\n                dotStyle += `background-color: transparent; border: 3px solid ${cell.isPrevMonth ? '#7d3a37' : '#FE5F58'}; color: ${missedTextColor};`;\n            }\n        } else {\n            dotStyle += `background-color: transparent; color: ${cell.isPrevMonth ? '#666' : 'var(--text-muted)'};`;\n        }\n        if (cell.isToday && cell.hasData) dotStyle += 'box-shadow: 0 0 0 3px var(--interactive-accent);';\n        \n        let lineHTML = '';\n        const leftLineColor = (hasLineFromPrev && prevCell.isPrevMonth && cell.isPrevMonth) ? '#1a5c28' : lineColor;\n        const rightLineColor = (hasLineToNext && cell.isPrevMonth && nextCell.isPrevMonth) ? '#1a5c28' : lineColor;\n        \n        if (hasLineFromPrev) lineHTML += `<div style=\"position: absolute; width: calc(50% + 12px); height: 3px; background-color: ${leftLineColor}; top: 50%; left: -12px; transform: translateY(-50%); z-index: 1;\"></div>`;\n        if (hasLineToNext) lineHTML += `<div style=\"position: absolute; width: calc(50% + 12px); height: 3px; background-color: ${rightLineColor}; top: 50%; right: -12px; transform: translateY(-50%); z-index: 1;\"></div>`;\n        if (hasWrapLineFromPrev) lineHTML += `<div style=\"position: absolute; width: calc(50% + 12px); height: 3px; background-color: ${leftLineColor}; top: 50%; left: -12px; transform: translateY(-50%); z-index: 1;\"></div>`;\n        if (hasWrapLineToNext) lineHTML += `<div style=\"position: absolute; width: calc(50% + 12px); height: 3px; background-color: ${rightLineColor}; top: 50%; right: -12px; transform: translateY(-50%); z-index: 1;\"></div>`;\n        \n        html += `<div style=\"text-align: center; position: relative; height: 50px;\">${lineHTML}<div class=\"date-link\" data-date=\"${cell.dateKey}\" style=\"${dotStyle}\">${cell.day}</div></div>`;\n    });\n\n    let extraStatHtml = '';\n    if (countLabel !== 'none') {\n        extraStatHtml = `\n        <div style=\"margin-top: 15px; padding: 15px; background: var(--background-secondary); border-radius: 8px; text-align: center;\">\n            <div style=\"font-size: 2em; font-weight: 700; color: #3b82f6;\">${totalCount}</div>\n            <div style=\"font-size: 0.9em; color: var(--text-muted); margin-top: 4px;\">$Total System Design Topics</div>\n        </div>\n        `;\n    }\n\n    html += `\n    </div>\n    <div style=\"margin-top: 20px; display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; padding: 15px; background: var(--background-secondary); border-radius: 8px;\">\n        <div style=\"text-align: center;\"><div style=\"font-size: 1.5em; font-weight: 700; color: #2CC742;\">${stats.currentStreak}</div><div style=\"font-size: 0.85em; color: var(--text-muted); margin-top: 4px;\">Current Streak</div></div>\n        <div style=\"text-align: center;\"><div style=\"font-size: 1.5em; font-weight: 700; color: #DAA520;\">${stats.longestStreak}</div><div style=\"font-size: 0.85em; color: var(--text-muted); margin-top: 4px;\">Longest Streak</div></div>\n        <div style=\"text-align: center;\"><div style=\"font-size: 1.5em; font-weight: 700; color: #FE5F58;\">${stats.longestBreak}</div><div style=\"font-size: 0.85em; color: var(--text-muted); margin-top: 4px;\">Longest Break</div></div>\n        <div style=\"text-align: center;\"><div style=\"font-size: 1.5em; font-weight: 700; color: var(--text-normal);\">${stats.completionPercentage}%</div><div style=\"font-size: 0.85em; color: var(--text-muted); margin-top: 4px;\">Completion %</div></div>\n        <div style=\"text-align: center;\"><div style=\"font-size: 1.5em; font-weight: 700; color: var(--text-normal);\">${stats.totalCompleted}</div><div style=\"font-size: 0.85em; color: var(--text-muted); margin-top: 4px;\">Total Days</div></div>\n    </div>\n    ${extraStatHtml}\n    `;\n    return html;\n}\n\nlet currentOffset = 0;\nconst container = dv.container;\ncontainer.innerHTML = `<div id=\"${containerId}\" style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\">${renderCalendar(currentOffset)}</div>`;\n\nfunction setupListeners() {\n    const calendarDiv = container.querySelector(`#${containerId}`);\n    calendarDiv.querySelector('.prev-month').addEventListener('click', () => { currentOffset--; calendarDiv.innerHTML = renderCalendar(currentOffset); setupListeners(); });\n    calendarDiv.querySelector('.next-month').addEventListener('click', () => { currentOffset++; calendarDiv.innerHTML = renderCalendar(currentOffset); setupListeners(); });\n    calendarDiv.querySelectorAll('.date-link').forEach(link => {\n        link.addEventListener('click', (e) => {\n            const dateKey = e.target.getAttribute('data-date');\n            app.workspace.openLinkText(`🔱 DSA/📆 Daily Prep Tracker/${dateKey}.md`, '', false);\n        });\n    });\n}\nsetupListeners();\n```",
			"styleAttributes":{},
			"x":-100,
			"y":-1080,
			"width":480,
			"height":760
		},
		{
			"id":"node3",
			"type":"text",
			"text":"```dataviewjs\n// Configuration\nconst habitProperty = \"linkedin_completed\"; // The property to track\nconst habitTitle = \"💼 LinkedIn\";\nconst countLabel = \"none\"; // Custom label for total count\n\n// Create a unique ID for this calendar instance\nconst containerId = `habit-calendar-${habitProperty}`;\n\n// Function to calculate streak statistics\nfunction calculateStreaks(habitData, year, month) {\n    const allDates = Array.from(habitData.entries())\n        .filter(([date, completed]) => completed === true)\n        .map(([date]) => date)\n        .sort();\n    \n    const totalDays = habitData.size;\n    const completedDays = allDates.length;\n    const completionPercentage = totalDays > 0 ? Math.round((completedDays / totalDays) * 100) : 0;\n    \n    if (allDates.length === 0) {\n        return { currentStreak: 0, longestStreak: 0, longestBreak: 0, totalCompleted: 0, completionPercentage: completionPercentage };\n    }\n    \n    let currentStreak = 0;\n    let longestStreak = 0;\n    let longestBreak = 0;\n    let tempStreak = 1;\n    let tempBreak = 0;\n    \n    const today = dv.date(\"today\").toFormat('yyyy-MM-dd');\n    const yesterday = dv.date(\"today\").minus({days: 1}).toFormat('yyyy-MM-dd');\n    \n    if (allDates.includes(today) || allDates.includes(yesterday)) {\n        let checkDate = allDates.includes(today) ? dv.date(\"today\") : dv.date(\"today\").minus({days: 1});\n        currentStreak = 0;\n        while (true) {\n            const dateKey = checkDate.toFormat('yyyy-MM-dd');\n            if (habitData.get(dateKey) === true) {\n                currentStreak++;\n                checkDate = checkDate.minus({days: 1});\n            } else {\n                break;\n            }\n        }\n    }\n    \n    for (let i = 1; i < allDates.length; i++) {\n        const prevDate = dv.date(allDates[i - 1]);\n        const currDate = dv.date(allDates[i]);\n        const daysDiff = currDate.diff(prevDate, 'days').days;\n        \n        if (daysDiff === 1) {\n            tempStreak++;\n            if (tempBreak > 0) {\n                longestBreak = Math.max(longestBreak, tempBreak);\n                tempBreak = 0;\n            }\n        } else {\n            longestStreak = Math.max(longestStreak, tempStreak);\n            tempStreak = 1;\n            tempBreak = daysDiff - 1;\n            longestBreak = Math.max(longestBreak, tempBreak);\n        }\n    }\n    longestStreak = Math.max(longestStreak, tempStreak);\n    \n    return { currentStreak, longestStreak, longestBreak, totalCompleted: completedDays, completionPercentage };\n}\n\n// Function to render the calendar\nfunction renderCalendar(monthOffset) {\n    const currentDate = dv.date(\"today\").plus({months: monthOffset});\n    const year = currentDate.year;\n    const month = currentDate.month;\n\n    const pages = dv.pages('\"🔱 DSA/📆 Daily Prep Tracker\"')\n        .where(p => p.file.day && p[habitProperty] !== undefined)\n        .sort(p => p.file.day, 'asc');\n\n    const habitData = new Map();\n    let totalCount = 0;\n    \n    pages.forEach(p => {\n        const dateKey = p.file.day.toFormat('yyyy-MM-dd');\n        let isDone = false;\n        if (typeof p[habitProperty] === 'number') {\n            isDone = p[habitProperty] > 0;\n            totalCount += p[habitProperty];\n        } else {\n            isDone = p[habitProperty] === true;\n        }\n        habitData.set(dateKey, isDone);\n    });\n\n    const stats = calculateStreaks(habitData, year, month);\n    const firstDay = dv.date(`${year}-${String(month).padStart(2, '0')}-01`);\n    const lastDay = firstDay.plus({months: 1}).minus({days: 1});\n    const daysInMonth = lastDay.day;\n    const luxonWeekday = firstDay.weekday;\n    const startDayOfWeek = luxonWeekday === 7 ? 6 : luxonWeekday - 1;\n    const monthName = firstDay.toFormat('MMMM yyyy');\n    const todayKey = dv.date(\"today\").toFormat('yyyy-MM-dd');\n\n    const cells = [];\n    if (startDayOfWeek > 0) {\n        const prevMonthLastDay = firstDay.minus({days: 1});\n        const prevMonthDaysInMonth = prevMonthLastDay.day;\n        for (let i = startDayOfWeek - 1; i >= 0; i--) {\n            const day = prevMonthDaysInMonth - i;\n            const prevMonthDate = firstDay.minus({days: i + 1});\n            const dateKey = prevMonthDate.toFormat('yyyy-MM-dd');\n            cells.push({\n                isEmpty: false, isPrevMonth: true, day: day, dateKey: dateKey,\n                isCompleted: habitData.get(dateKey) === true, hasData: habitData.has(dateKey), isToday: dateKey === todayKey\n            });\n        }\n    }\n    for (let day = 1; day <= daysInMonth; day++) {\n        const dateKey = `${year}-${String(month).padStart(2, '0')}-${String(day).padStart(2, '0')}`;\n        cells.push({\n            isEmpty: false, isPrevMonth: false, day: day, dateKey: dateKey,\n            isCompleted: habitData.get(dateKey) === true, hasData: habitData.has(dateKey), isToday: dateKey === todayKey\n        });\n    }\n\n    let html = `\n    <h1 style=\"margin: 10px 0 20px 0; text-align: center;\">${habitTitle}</h1>\n    <div style=\"display: flex; align-items: center; justify-content: space-between; margin-bottom: 15px;\">\n        <button class=\"prev-month\" style=\"padding: 6px 12px; cursor: pointer; background: var(--interactive-normal); border: 1px solid var(--background-modifier-border); border-radius: 4px; color: var(--text-normal);\">← Prev</button>\n        <h3 style=\"margin: 0;\">${monthName}</h3>\n        <button class=\"next-month\" style=\"padding: 6px 12px; cursor: pointer; background: var(--interactive-normal); border: 1px solid var(--background-modifier-border); border-radius: 4px; color: var(--text-normal);\">Next →</button>\n    </div>\n    <div style=\"display: grid; grid-template-columns: repeat(7, 1fr); gap: 12px; margin-bottom: 15px;\">\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Mon</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Tue</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Wed</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Thu</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Fri</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Sat</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Sun</div>\n    `;\n\n    cells.forEach((cell, index) => {\n        if (cell.isEmpty) { html += '<div style=\"height: 50px;\"></div>'; return; }\n        const posInRow = index % 7;\n        const isLastInRow = posInRow === 6;\n        const isFirstInRow = posInRow === 0;\n        const prevCell = index > 0 ? cells[index - 1] : null;\n        const nextCell = index < cells.length - 1 ? cells[index + 1] : null;\n        \n        const hasLineFromPrev = prevCell && !prevCell.isEmpty && prevCell.isCompleted && cell.isCompleted && !isFirstInRow;\n        const hasLineToNext = nextCell && !nextCell.isEmpty && nextCell.isCompleted && cell.isCompleted && !isLastInRow;\n        const hasWrapLineFromPrev = prevCell && !prevCell.isEmpty && prevCell.isCompleted && cell.isCompleted && isFirstInRow;\n        const hasWrapLineToNext = nextCell && !nextCell.isEmpty && nextCell.isCompleted && cell.isCompleted && isLastInRow;\n        \n        const dotColor = cell.isPrevMonth ? '#1a5c28' : '#DAA520';\n        const lineColor = cell.isPrevMonth ? '#1a5c28' : '#DAA520';\n        const completedTextColor = cell.isPrevMonth ? '#888' : 'white';\n        const missedTextColor = cell.isPrevMonth ? '#888' : 'var(--text-normal)';\n        \n        let dotStyle = `width: 50px; height: 50px; border-radius: 50%; margin: 0 auto; position: relative; z-index: 2; display: flex; align-items: center; justify-content: center; font-weight: 500; font-size: 1em; cursor: pointer;`;\n        \n        if (cell.hasData) {\n            if (cell.isCompleted) {\n                dotStyle += `background-color: ${dotColor}; color: ${completedTextColor};`;\n            } else {\n                dotStyle += `background-color: transparent; border: 3px solid ${cell.isPrevMonth ? '#7d3a37' : '#FE5F58'}; color: ${missedTextColor};`;\n            }\n        } else {\n            dotStyle += `background-color: transparent; color: ${cell.isPrevMonth ? '#666' : 'var(--text-muted)'};`;\n        }\n        if (cell.isToday && cell.hasData) dotStyle += 'box-shadow: 0 0 0 3px var(--interactive-accent);';\n        \n        let lineHTML = '';\n        const leftLineColor = (hasLineFromPrev && prevCell.isPrevMonth && cell.isPrevMonth) ? '#1a5c28' : lineColor;\n        const rightLineColor = (hasLineToNext && cell.isPrevMonth && nextCell.isPrevMonth) ? '#1a5c28' : lineColor;\n        \n        if (hasLineFromPrev) lineHTML += `<div style=\"position: absolute; width: calc(50% + 12px); height: 3px; background-color: ${leftLineColor}; top: 50%; left: -12px; transform: translateY(-50%); z-index: 1;\"></div>`;\n        if (hasLineToNext) lineHTML += `<div style=\"position: absolute; width: calc(50% + 12px); height: 3px; background-color: ${rightLineColor}; top: 50%; right: -12px; transform: translateY(-50%); z-index: 1;\"></div>`;\n        if (hasWrapLineFromPrev) lineHTML += `<div style=\"position: absolute; width: calc(50% + 12px); height: 3px; background-color: ${leftLineColor}; top: 50%; left: -12px; transform: translateY(-50%); z-index: 1;\"></div>`;\n        if (hasWrapLineToNext) lineHTML += `<div style=\"position: absolute; width: calc(50% + 12px); height: 3px; background-color: ${rightLineColor}; top: 50%; right: -12px; transform: translateY(-50%); z-index: 1;\"></div>`;\n        \n        html += `<div style=\"text-align: center; position: relative; height: 50px;\">${lineHTML}<div class=\"date-link\" data-date=\"${cell.dateKey}\" style=\"${dotStyle}\">${cell.day}</div></div>`;\n    });\n\n    let extraStatHtml = '';\n    if (countLabel !== 'none') {\n        extraStatHtml = `\n        <div style=\"margin-top: 15px; padding: 15px; background: var(--background-secondary); border-radius: 8px; text-align: center;\">\n            <div style=\"font-size: 2em; font-weight: 700; color: #DAA520;\">${totalCount}</div>\n            <div style=\"font-size: 0.9em; color: var(--text-muted); margin-top: 4px;\">$none</div>\n        </div>\n        `;\n    }\n\n    html += `\n    </div>\n    <div style=\"margin-top: 20px; display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; padding: 15px; background: var(--background-secondary); border-radius: 8px;\">\n        <div style=\"text-align: center;\"><div style=\"font-size: 1.5em; font-weight: 700; color: #2CC742;\">${stats.currentStreak}</div><div style=\"font-size: 0.85em; color: var(--text-muted); margin-top: 4px;\">Current Streak</div></div>\n        <div style=\"text-align: center;\"><div style=\"font-size: 1.5em; font-weight: 700; color: #DAA520;\">${stats.longestStreak}</div><div style=\"font-size: 0.85em; color: var(--text-muted); margin-top: 4px;\">Longest Streak</div></div>\n        <div style=\"text-align: center;\"><div style=\"font-size: 1.5em; font-weight: 700; color: #FE5F58;\">${stats.longestBreak}</div><div style=\"font-size: 0.85em; color: var(--text-muted); margin-top: 4px;\">Longest Break</div></div>\n        <div style=\"text-align: center;\"><div style=\"font-size: 1.5em; font-weight: 700; color: var(--text-normal);\">${stats.completionPercentage}%</div><div style=\"font-size: 0.85em; color: var(--text-muted); margin-top: 4px;\">Completion %</div></div>\n        <div style=\"text-align: center;\"><div style=\"font-size: 1.5em; font-weight: 700; color: var(--text-normal);\">${stats.totalCompleted}</div><div style=\"font-size: 0.85em; color: var(--text-muted); margin-top: 4px;\">Total Days</div></div>\n    </div>\n    ${extraStatHtml}\n    `;\n    return html;\n}\n\nlet currentOffset = 0;\nconst container = dv.container;\ncontainer.innerHTML = `<div id=\"${containerId}\" style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\">${renderCalendar(currentOffset)}</div>`;\n\nfunction setupListeners() {\n    const calendarDiv = container.querySelector(`#${containerId}`);\n    calendarDiv.querySelector('.prev-month').addEventListener('click', () => { currentOffset--; calendarDiv.innerHTML = renderCalendar(currentOffset); setupListeners(); });\n    calendarDiv.querySelector('.next-month').addEventListener('click', () => { currentOffset++; calendarDiv.innerHTML = renderCalendar(currentOffset); setupListeners(); });\n    calendarDiv.querySelectorAll('.date-link').forEach(link => {\n        link.addEventListener('click', (e) => {\n            const dateKey = e.target.getAttribute('data-date');\n            app.workspace.openLinkText(`🔱 DSA/📆 Daily Prep Tracker/${dateKey}.md`, '', false);\n        });\n    });\n}\nsetupListeners();\n```",
			"styleAttributes":{},
